#cloud-config
hostname: ubuntu-2404-cloudimg
manage_etc_hosts: true

users:
  - default
  - name: ubuntu
    groups:
      - adm
      - sudo
    lock_passwd: false
    shell: /bin/bash
    sudo: ALL=(ALL) NOPASSWD:ALL

ssh_pwauth: true

chpasswd:
  expire: false
  users:
    - name: ubuntu
      password: ubuntu
      type: text

package_update: true
packages:
  - ca-certificates
  - cloud-init
  - curl
  - gnupg
  - qemu-guest-agent
  - vim

runcmd:
  - systemctl enable --now qemu-guest-agent
